# ============================================
# Configuracion de n8n - Entorno Educativo
# ============================================
# Copia este archivo como .env y ajusta los valores
#   cp .env.example .env  (Linux/Mac)
#   copy .env.example .env  (Windows)

# Puerto en el que n8n escucha (por defecto 5678)
N8N_PORT=5678

# Zona horaria (formato tz database)
TIMEZONE=Europe/Madrid

# Paquetes npm accesibles desde los Code nodes de n8n
# Necesario para el workflow 22 (Convertidor Excel Masivo)
NODE_FUNCTION_ALLOW_EXTERNAL=xlsx
NODE_FUNCTION_ALLOW_BUILTIN=fs,path
