# ============================================
# Configuracion de n8n - Entorno Educativo
# ============================================
# Copia este archivo como .env y ajusta los valores
#   cp .env.example .env  (Linux/Mac)
#   copy .env.example .env  (Windows)

# Puerto en el que n8n escucha (por defecto 5678)
N8N_PORT=5678

# Zona horaria (formato tz database)
TIMEZONE=Europe/Madrid
